---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandIcon from '../components/common/BrandIcon.astro';
import CtaButton from '../components/common/CtaButton.astro';
---
<BaseLayout
  title="ページが見つかりません – MiniDeck"
  description="お探しのページは見つかりませんでした。トップページから最新版のダウンロードにお進みください。"
>
  <main class="min-h-[80svh] flex items-center justify-center px-6">
    <div class="max-w-md text-center">
      <BrandIcon class="text-md-accent mx-auto" size={56} />
      <p class="mt-6 text-sm font-semibold tracking-[0.25em] text-md-accent">404 NOT FOUND</p>
      <h1 class="mt-3 text-3xl md:text-4xl font-bold text-md-text-strong leading-[1.4]">
        ページが見つかりません
      </h1>
      <p class="mt-4 text-md-text leading-[1.9]">
        お探しのページは移動または削除された可能性があります。
      </p>
      <CtaButton href="/" class="mt-8 px-8 py-4 text-base min-h-[56px]">
        トップページへ戻る
      </CtaButton>
    </div>
  </main>
</BaseLayout>
